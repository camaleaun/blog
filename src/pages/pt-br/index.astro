---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/formatDate";
import { truncateSummary } from "../../lib/truncateSummary";
import { sanitizeEmoji } from "../../lib/sanitizeEmoji";
import { getPostThumbnail } from "../../lib/getPostThumbnail";

const posts = (await getCollection("postsPt"))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Blog" description="Posts em portugues" locale="pt-BR" enUrl={baseUrl} ptUrl={`${baseUrl}pt-br/`}>
  <header>
    <h1>Posts</h1>
    <p>Posts em portugues do blog.</p>
  </header>

  <section class="post-grid">
    {posts.map((post) => {
      const thumbnail = getPostThumbnail(post.data.slug, "pt-BR", post.data.origin);

      return (
        <article class="post-card">
          <a class="post-card-media" href={`${baseUrl}pt-br/${post.data.slug}/`}>
            {thumbnail && (
              <Image
                src={thumbnail}
                alt={`Miniatura de ${post.data.title}`}
                loading="lazy"
                widths={[288, 576]}
                sizes="(max-width: 640px) 100vw, 288px"
              />
            )}
            {!thumbnail && <div class="thumb-placeholder" aria-hidden="true"></div>}
          </a>
          <div class="post-card-body">
            <a class="post-card-title" href={`${baseUrl}pt-br/${post.data.slug}/`}>
            <h2>{sanitizeEmoji(post.data.title)}</h2>
            </a>
            <div class="post-card-footer">
              <p>{truncateSummary(sanitizeEmoji(post.data.description))}</p>
              <small>{formatDate(post.data.pubDate, "pt-BR")}</small>
            </div>
          </div>
        </article>
      );
    })}
  </section>
</BaseLayout>
