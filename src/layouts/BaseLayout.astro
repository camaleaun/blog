---
import "../styles/site.css";

interface Props {
  title: string;
  description?: string;
  locale?: "en" | "pt-BR";
  enUrl?: string;
  ptUrl?: string;
}

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const {
  title,
  description = "Blog",
  locale = "en",
  enUrl = baseUrl,
  ptUrl = `${baseUrl}pt-br/`
} = Astro.props;

const htmlLang = locale === "pt-BR" ? "pt-BR" : "en";
const languageLabel = locale === "pt-BR" ? "Portugues (BR)" : "English";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme-mode") || "auto";
        const resolved =
          stored === "auto"
            ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
            : stored;
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-mode", stored);
      })();
    </script>
  </head>
  <body>
    <main class="shell">
      <div class="topbar">
        <a class="home-link" href={locale === "pt-BR" ? `${baseUrl}pt-br/` : baseUrl}>Blog</a>
        <div class="topbar-tools">
          <div id="language-dropdown" class="nav-dropdown nav-dropdown--language" role="navigation" aria-label="Language switcher">
            <button id="language-trigger" class="nav-dropdown-trigger" type="button" aria-haspopup="true" aria-expanded="false">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" class="icon-language">
                <path fill="currentColor" d="M12.87 15.07l-2.54-2.51.03-.03c1.74-1.94 2.98-4.17 3.71-6.53H17V4h-7V2H8v2H1v1.99h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z"></path>
              </svg>
              <span>{languageLabel}</span>
            </button>
            <ul class="nav-dropdown-menu" role="menu">
              <li><a href={enUrl} class={locale === "en" ? "active" : ""} lang="en">English</a></li>
              <li><a href={ptUrl} class={locale === "pt-BR" ? "active" : ""} lang="pt-BR">Portugues (BR)</a></li>
            </ul>
          </div>

          <div id="theme-dropdown" class="nav-dropdown nav-dropdown--theme" role="navigation" aria-label="Theme switcher">
            <button id="theme-trigger" class="nav-dropdown-trigger" type="button" aria-haspopup="true" aria-expanded="false">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" class="icon-theme icon-theme-light">
                <path fill="currentColor" d="M12 18a1 1 0 0 1 1 1v2a1 1 0 1 1-2 0v-2a1 1 0 0 1 1-1zm0-16a1 1 0 0 1 1 1v2a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1zm9 9a1 1 0 1 1 0 2h-2a1 1 0 1 1 0-2h2zM5 12a1 1 0 1 1 0 2H3a1 1 0 1 1 0-2h2zm11.66 6.66a1 1 0 0 1 1.41 0l1.42 1.42a1 1 0 0 1-1.41 1.41l-1.42-1.41a1 1 0 0 1 0-1.42zM4.51 4.51a1 1 0 0 1 1.41 0l1.42 1.42a1 1 0 1 1-1.41 1.41L4.51 5.93a1 1 0 0 1 0-1.42zm13.58 2.83a1 1 0 0 1 0-1.41l1.41-1.42a1 1 0 1 1 1.42 1.41l-1.42 1.42a1 1 0 0 1-1.41 0zM5.93 16.66a1 1 0 0 1 1.41 1.41l-1.42 1.42a1 1 0 0 1-1.41-1.41l1.42-1.42zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10z"></path>
              </svg>
              <span id="theme-label">Theme</span>
            </button>
            <ul class="nav-dropdown-menu" role="menu">
              <li><button class="dropdown-option" type="button" data-theme-value="light">Light</button></li>
              <li><button class="dropdown-option" type="button" data-theme-value="dark">Dark</button></li>
              <li><button class="dropdown-option" type="button" data-theme-value="auto">Auto</button></li>
            </ul>
          </div>
        </div>
      </div>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const applyTheme = (mode) => {
          const resolved =
            mode === "auto"
              ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
              : mode;

          document.documentElement.setAttribute("data-theme", resolved);
          document.documentElement.setAttribute("data-theme-mode", mode);
          localStorage.setItem("theme-mode", mode);

          const label = document.getElementById("theme-label");
          if (label) {
            label.textContent = mode === "auto" ? "Auto" : mode[0].toUpperCase() + mode.slice(1);
          }

          document.querySelectorAll(".dropdown-option[data-theme-value]").forEach((btn) => {
            const isActive = btn.getAttribute("data-theme-value") === mode;
            btn.classList.toggle("active", isActive);
            btn.setAttribute("aria-pressed", isActive ? "true" : "false");
          });
        };

        const current = document.documentElement.getAttribute("data-theme-mode") || "auto";
        applyTheme(current);

        const languageDropdown = document.getElementById("language-dropdown");
        const languageTrigger = document.getElementById("language-trigger");
        const themeDropdown = document.getElementById("theme-dropdown");
        const themeTrigger = document.getElementById("theme-trigger");

        const setLanguageDropdownOpen = (isOpen) => {
          if (!languageDropdown || !languageTrigger) {
            return;
          }

          languageDropdown.classList.toggle("is-open", isOpen);
          languageTrigger.setAttribute("aria-expanded", isOpen ? "true" : "false");
        };

        const setThemeDropdownOpen = (isOpen) => {
          if (!themeDropdown || !themeTrigger) {
            return;
          }

          themeDropdown.classList.toggle("is-open", isOpen);
          themeTrigger.setAttribute("aria-expanded", isOpen ? "true" : "false");
        };

        languageTrigger?.addEventListener("click", (event) => {
          event.stopPropagation();
          const willOpen = !languageDropdown?.classList.contains("is-open");
          setLanguageDropdownOpen(Boolean(willOpen));
          setThemeDropdownOpen(false);
        });

        languageDropdown?.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            setLanguageDropdownOpen(false);
          });
        });

        themeTrigger?.addEventListener("click", (event) => {
          event.stopPropagation();
          const willOpen = !themeDropdown?.classList.contains("is-open");
          setThemeDropdownOpen(Boolean(willOpen));
          setLanguageDropdownOpen(false);
        });

        document.querySelectorAll(".dropdown-option[data-theme-value]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const mode = btn.getAttribute("data-theme-value");
            if (mode) {
              applyTheme(mode);
            }

            setThemeDropdownOpen(false);
          });
        });

        document.addEventListener("click", (event) => {
          if (!languageDropdown || !languageDropdown.contains(event.target)) {
            setLanguageDropdownOpen(false);
          }

          if (!themeDropdown || !themeDropdown.contains(event.target)) {
            setThemeDropdownOpen(false);
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            setLanguageDropdownOpen(false);
            setThemeDropdownOpen(false);
          }
        });

        const media = window.matchMedia("(prefers-color-scheme: dark)");
        media.addEventListener("change", () => {
          const mode = document.documentElement.getAttribute("data-theme-mode") || "auto";
          if (mode === "auto") {
            applyTheme("auto");
          }
        });
      })();
    </script>
  </body>
</html>
